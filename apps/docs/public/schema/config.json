{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vayu.design/schema/config.json",
  "title": "Vayu UI Config",
  "description": "Schema for vayu-ui.config.json generated by the Vayu UI CLI.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "uiPath",
    "cssFile",
    "tokensFile",
    "installed"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference URL."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "uiPath": {
      "type": "string",
      "minLength": 1
    },
    "cssFile": {
      "type": [
        "string",
        "null"
      ]
    },
    "tokensFile": {
      "type": "string",
      "minLength": 1
    },
    "installed": {
      "type": "object",
      "description": "Map of installed slugs to install metadata.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "installedAt"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "component",
              "hook"
            ]
          },
          "installedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
